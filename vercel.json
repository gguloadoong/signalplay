{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "50 23 * * *"
    },
    {
      "path": "/api/cron/set-result",
      "schedule": "0 7 * * *"
    }
  ]
}
